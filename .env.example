# =============================================================================
# ENVIRONMENT VARIABLES - Copy this file to .env and fill in your values
# =============================================================================

# scrape.do proxy API token (required for tender scraping)
# Sign up at https://scrape.do to get your token
SCRAPE_DO_TOKEN=your_scrape_do_token_here

# ASX API access token (required for ASX announcement scraping)
# This is the public token used by the ASX website
ASX_ACCESS_TOKEN=83ff96335c2d45a094df02a206a39ff4

# Flask dashboard credentials (change these for production)
FLASK_SECRET_KEY=change-me-to-a-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# =============================================================================
# ICN GATEWAY (gateway.icn.org.au)
# =============================================================================
# This portal requires 2FA login. You must manually log in via your browser,
# then export your session cookies to icn_cookies.json in the project root.
#
# Required cookies: PHPSESSID, gateway_by_icn_session, remember_tfa_gateway, XSRF-TOKEN
#
# How to export cookies:
#   1. Log in to https://gateway.icn.org.au in Chrome
#   2. Open DevTools (F12) > Application > Cookies > gateway.icn.org.au
#   3. Copy the 4 cookie values into icn_cookies.json:
#      {
#        "PHPSESSID": "your_value",
#        "remember_tfa_gateway": "your_value",
#        "XSRF-TOKEN": "your_value",
#        "gateway_by_icn_session": "your_value"
#      }
#   4. The scraper will auto-update the file as cookies rotate.
#
# Sessions typically last several hours. Re-export if scraper reports "session expired".
